<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="background_color">#121212</color>
    <color name="black">#FF000000</color>
    <color name="button_clear_bg">#F44336</color>
    <color name="button_function_bg">#4CAF50</color>
    <color name="button_number_bg">#2D2D2D</color>
    <color name="button_operator_bg">#FF9800</color>
    <color name="button_text_color">#FFFFFF</color>
    <color name="display_background">#1E1E1E</color>
    <color name="display_text_main">#FFFFFF</color>
    <color name="display_text_secondary">#888888</color>
    <color name="white">#FFFFFFFF</color>
    <string name="app_name">Scientific Calculator</string>
    <style name="CalcButton" parent="Widget.MaterialComponents.Button">
        
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textColor">@color/button_text_color</item>
        <item name="android:textSize">18sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="CalcButton.Clear">
        <item name="backgroundTint">@color/button_clear_bg</item>
        <item name="android:textSize">20sp</item>
    </style>
    <style name="CalcButton.Number">
        <item name="backgroundTint">@color/button_number_bg</item>
        <item name="android:textSize">24sp</item>
    </style>
    <style name="CalcButton.Operator">
        <item name="backgroundTint">@color/button_operator_bg</item>
        <item name="android:textSize">24sp</item>
    </style>
    <style name="CalcButton.Scientific">
        <item name="backgroundTint">@color/button_function_bg</item>
        <item name="android:textSize">16sp</item>
        <item name="textAllCaps">false</item>
    </style>
    <style name="Theme.ScientificCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/button_operator_bg</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor" ns1:targetApi="l">@color/background_color</item>
        <item name="android:windowBackground">@color/background_color</item>
    </style>
</resources>